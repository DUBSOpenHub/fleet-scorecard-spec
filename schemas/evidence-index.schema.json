{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DUBSOpenHub/fleet-scorecard-spec/schemas/evidence-index.schema.json",
  "title": "Fleet Scorecard Evidence Index",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "run_id",
    "backend",
    "status",
    "fleet_score",
    "decision",
    "scorecard_path",
    "sources",
    "caveats",
    "generated_at"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "backend": {
      "type": "string",
      "minLength": 1
    },
    "repo_path": {
      "type": "string"
    },
    "source_run_path": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "fleet_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "decision": {
      "$ref": "#/$defs/decision"
    },
    "seal_verified": {
      "type": "boolean"
    },
    "criteria_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "scorecard_path": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["path", "kind", "summary"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed", "running"]
    },
    "decision": {
      "type": "string",
      "enum": ["run again", "run again with changes", "wait for completion", "do not rerun"]
    }
  }
}
